# .pen files are binary — track with LFS, enable locking
*.pen filter=lfs diff=lfs merge=lfs -text lockable

# Images
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.svg filter=lfs diff=lfs merge=lfs -text

# Rules files are text, normal merge
*.rules.md merge=text
